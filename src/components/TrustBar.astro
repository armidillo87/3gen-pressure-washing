---
interface Props {
  signals?: {
    icon: string;
    text: string;
    subtext?: string;
    image?: string;
  }[];
}

const { signals = [] } = Astro.props;
---

<section class="trust-bar">
  <div class="container">
    <div class="trust-bar__grid">
      {signals.map(signal => (
        <div class="trust-bar__signal">
          <div class="trust-bar__icon">
            {signal.image ? (
              <img src={signal.image} alt={signal.text} class="trust-bar__badge-img" width="40" height="40" loading="eager" />
            ) : (
              <>
                {signal.icon === 'star' && <svg xmlns="http://www.w3.org/2000/svg" fill="currentColor" viewBox="0 0 24 24" style="width: 28px; height: 28px;"><path d="M11.48 3.499a.562.562 0 011.04 0l2.125 5.111a.563.563 0 00.475.345l5.518.442c.499.04.701.663.321.988l-4.204 3.602a.563.563 0 00-.182.557l1.285 5.385a.562.562 0 01-.84.61l-4.725-2.885a.563.563 0 00-.586 0L6.982 20.54a.562.562 0 01-.84-.61l1.285-5.386a.562.562 0 00-.182-.557l-4.204-3.602a.563.563 0 01.321-.988l5.518-.442a.563.563 0 00.475-.345L11.48 3.5z" /></svg>}
                {signal.icon === 'shield' && <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" style="width: 28px; height: 28px;"><path stroke-linecap="round" stroke-linejoin="round" d="M9 12.75L11.25 15 15 9.75m-3-7.036A11.959 11.959 0 013.598 6 11.99 11.99 0 003 9.749c0 5.592 3.824 10.29 9 11.623 5.176-1.332 9-6.03 9-11.622 0-1.31-.21-2.571-.598-3.751h-.152c-3.196 0-6.1-1.248-8.25-3.285z" /></svg>}
                {signal.icon === 'clock' && <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" style="width: 28px; height: 28px;"><path stroke-linecap="round" stroke-linejoin="round" d="M12 6v6h4.5m4.5 0a9 9 0 11-18 0 9 9 0 0118 0z" /></svg>}
                {signal.icon === 'family' && <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" style="width: 28px; height: 28px;"><path stroke-linecap="round" stroke-linejoin="round" d="M18 18.72a9.094 9.094 0 003.741-.479 3 3 0 00-4.682-2.72m.94 3.198l.001.031c0 .225-.012.447-.037.666A11.944 11.944 0 0112 21c-2.17 0-4.207-.576-5.963-1.584A6.062 6.062 0 016 18.719m12 0a5.971 5.971 0 00-.941-3.197m0 0A5.995 5.995 0 0012 12.75a5.995 5.995 0 00-5.058 2.772m0 0a3 3 0 00-4.681 2.72 8.986 8.986 0 003.74.477m.94-3.197a5.971 5.971 0 00-.94 3.197M15 6.75a3 3 0 11-6 0 3 3 0 016 0zm6 3a2.25 2.25 0 11-4.5 0 2.25 2.25 0 014.5 0zm-13.5 0a2.25 2.25 0 11-4.5 0 2.25 2.25 0 014.5 0z" /></svg>}
                {signal.icon === 'award' && <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" style="width: 28px; height: 28px;"><path stroke-linecap="round" stroke-linejoin="round" d="M16.5 18.75h-9m9 0a3 3 0 013 3h-15a3 3 0 013-3m9 0v-3.375c0-.621-.503-1.125-1.125-1.125h-.871M7.5 18.75v-3.375c0-.621.504-1.125 1.125-1.125h.872m5.007 0H9.497m5.007 0a7.454 7.454 0 01-.982-3.172M9.497 14.25a7.454 7.454 0 00.981-3.172M5.25 4.236c-.982.143-1.954.317-2.916.52A6.003 6.003 0 007.73 9.728M5.25 4.236V4.5c0 2.108.966 3.99 2.48 5.228M5.25 4.236V2.721C7.456 2.41 9.71 2.25 12 2.25c2.291 0 4.545.16 6.75.47v1.516M7.73 9.728a6.726 6.726 0 002.748 1.35m8.272-6.842V4.5c0 2.108-.966 3.99-2.48 5.228m2.48-5.492a46.32 46.32 0 012.916.52 6.003 6.003 0 01-5.395 4.972m0 0a6.726 6.726 0 01-2.749 1.35m0 0a6.772 6.772 0 01-3.044 0" /></svg>}
              </>
            )}
          </div>
          <div class="trust-bar__text">
            <strong>{signal.text}</strong>
            {signal.subtext && <small>{signal.subtext}</small>}
          </div>
        </div>
      ))}
    </div>
  </div>
</section>

<style>
  .trust-bar {
    background: var(--charcoal);
    position: relative;
    color: #fff;
    padding: 1.75rem 0;
    border-top: 3px solid var(--forest);
    box-shadow: 0 -4px 30px rgba(0, 86, 179, 0.15), inset 0 20px 40px rgba(0, 0, 0, 0.4);
    border-bottom: 1px solid rgba(255, 255, 255, 0.05);
    z-index: 10;
  }
  
  .trust-bar__grid {
    display: flex;
    justify-content: center;
    align-items: center;
    flex-wrap: wrap;
    gap: 2.5rem;
  }
  
  .trust-bar__signal {
    display: flex;
    align-items: center;
    gap: 0.85rem;
    padding: 0.5rem 1rem;
    border-radius: var(--radius-sm);
    transition: all 0.3s ease;
  }

  .trust-bar__signal:hover {
    background: rgba(255, 255, 255, 0.04);
    transform: translateY(-2px);
  }
  
  .trust-bar__icon {
    color: var(--forest-light);
    display: flex;
    align-items: center;
    justify-content: center;
    filter: drop-shadow(0 0 8px rgba(0, 188, 212, 0.4));
  }

  .trust-bar__badge-img {
    width: 40px;
    height: 40px;
    object-fit: contain;
    border-radius: 4px;
  }
  
  .trust-bar__text {
    display: flex;
    flex-direction: column;
    text-align: left;
  }
  
  .trust-bar__text strong {
    text-transform: uppercase;
    font-size: 0.9rem;
    letter-spacing: 0.06em;
    font-family: var(--font-heading);
    color: var(--text-on-dark);
  }
  
  .trust-bar__text small {
    font-size: 0.8rem;
    color: var(--text-on-dark-dim);
    margin-top: 2px;
  }
  
  @media (max-width: 768px) {
    .trust-bar__grid {
      gap: 1.25rem;
      justify-content: flex-start;
    }
    .trust-bar__signal {
      flex: 1 1 calc(50% - 1.25rem);
      padding: 0.25rem;
    }
  }
</style>
