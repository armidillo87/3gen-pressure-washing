---
import siteConfig from '@/data/site-config.json';
import servicesData from '@/data/services.json';
const { business, social } = siteConfig;
const currentYear = new Date().getFullYear();
---

<footer class="footer" slot="footer">
  <div class="container footer__upper">
    <div class="footer__brand">
      <span class="footer__brand-name">{business.name}</span>
      <p class="footer__brand-desc">Women & minority-owned. Family operated. Proudly serving Spokane, WA and surrounding communities since {business.yearEstablished}.</p>
      <div class="footer__credentials">
        <div class="footer__credential">
          <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" style="width:16px;height:16px;color:var(--forest-light);flex-shrink:0;">
            <path stroke-linecap="round" stroke-linejoin="round" d="M9 12.75L11.25 15 15 9.75m-3-7.036A11.959 11.959 0 013.598 6 11.99 11.99 0 003 9.749c0 5.592 3.824 10.29 9 11.623 5.176-1.332 9-6.03 9-11.622 0-1.31-.21-2.571-.598-3.751h-.152c-3.196 0-6.1-1.248-8.25-3.285z" />
          </svg>
          <span>WA Contractor Reg. #{business.licenseNumber}</span>
        </div>
        <div class="footer__credential">
          <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" style="width:16px;height:16px;color:var(--forest-light);flex-shrink:0;">
            <path stroke-linecap="round" stroke-linejoin="round" d="M11.35 3.836c-.065.21-.1.433-.1.664 0 .414.336.75.75.75h4.5a.75.75 0 00.75-.75 2.25 2.25 0 00-.1-.664m-5.8 0A2.251 2.251 0 0113.5 2.25H15c1.012 0 1.867.668 2.15 1.586m-5.8 0c-.376.023-.75.05-1.124.08C9.095 4.01 8.25 4.973 8.25 6.108V8.25m8.9-4.414c.376.023.75.05 1.124.08 1.131.094 1.976 1.057 1.976 2.192V16.5A2.25 2.25 0 0118 18.75h-2.25m-7.5-10.5H4.875c-.621 0-1.125.504-1.125 1.125v11.25c0 .621.504 1.125 1.125 1.125h9.75c.621 0 1.125-.504 1.125-1.125V18.75m-7.5-10.5h6.375c.621 0 1.125.504 1.125 1.125v9.375m-8.25-3h5.25m-5.25 3h5.25" />
          </svg>
          <span>WA Business License #{business.businessLicense}</span>
        </div>
        <div class="footer__credential">
          <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" style="width:16px;height:16px;color:var(--forest-light);flex-shrink:0;">
            <path stroke-linecap="round" stroke-linejoin="round" d="M13.5 6H5.25A2.25 2.25 0 003 8.25v10.5A2.25 2.25 0 005.25 21h10.5A2.25 2.25 0 0018 18.75V10.5m-10.5 6L21 3m0 0h-5.25M21 3v5.25" />
          </svg>
          <a href="https://protectmyhome.net/" target="_blank" rel="noopener noreferrer" class="footer__verify-link">Verify us at ProtectMyHome.net</a>
        </div>
      </div>
      <div class="footer__social">
        {social.facebook && <a href={social.facebook} class="footer__social-icon" aria-label="Facebook" target="_blank" rel="noopener noreferrer">f</a>}
        {social.instagram && <a href={social.instagram} class="footer__social-icon" aria-label="Instagram" target="_blank" rel="noopener noreferrer">ig</a>}
        {social.google && <a href={social.google} class="footer__social-icon" aria-label="Google" target="_blank" rel="noopener noreferrer">G</a>}
      </div>
    </div>

    <div>
      <h4 class="footer__heading">Services</h4>
      {servicesData.filter((s: any) => s.isPopular).map((service: any) => (
        <a href={`/services/${service.slug}/`} class="footer__link">{service.shortName}</a>
      ))}
      <a href="/services/" class="footer__link footer__view-all">View All Services &rarr;</a>
    </div>

    <div>
      <h4 class="footer__heading">Company</h4>
      <a href="/about/" class="footer__link">About Us</a>
      <a href="/contact/" class="footer__link">Contact</a>
      <a href="/review/" class="footer__link">Leave a Review</a>
      <a href="/service-areas/" class="footer__link">Service Areas</a>
    </div>

    <div>
      <h4 class="footer__heading">Contact</h4>
      <a href={`tel:${business.phoneClean}`} class="footer__link footer__phone">{business.phone}</a>
      <a href={`mailto:${business.email}`} class="footer__link">{business.email}</a>
      <span class="footer__link">{business.hours.display}</span>
      <span class="footer__link" style="margin-top: 0.75rem; font-size: 0.8rem; opacity: 0.7;">{business.address.city}, {business.address.state}</span>
    </div>
  </div>

  <div class="container footer__bottom">
    <span>&copy; {currentYear} {business.legalName}. All rights reserved.</span>
    <span>
      <a href="/privacy/" class="footer__legal-link">Privacy Policy</a> &nbsp;|&nbsp;
      <a href="/terms/" class="footer__legal-link">Terms of Service</a> &nbsp;|&nbsp;
      <a href="/accessibility/" class="footer__legal-link">Accessibility</a>
    </span>
  </div>
</footer>

<style>
  .footer__brand-name {
    font-family: var(--font-heading);
    font-size: 1.25rem;
    font-weight: 800;
    color: white;
  }
  .footer__credentials {
    display: flex;
    flex-direction: column;
    gap: 0.5rem;
    margin-top: 1rem;
    margin-bottom: 1rem;
  }
  .footer__credential {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    font-size: 0.82rem;
    color: var(--text-on-dark-dim);
  }
  .footer__verify-link {
    color: var(--forest-light);
    text-decoration: underline;
    text-underline-offset: 2px;
    transition: color 0.2s;
  }
  .footer__verify-link:hover {
    color: #FFFFFF;
  }
  .footer__view-all {
    margin-top: 0.5rem;
    font-weight: bold;
    color: var(--forest-light) !important;
  }
  .footer__phone {
    font-weight: 700;
    color: var(--forest-light) !important;
    font-size: 1.05rem;
  }
  .footer__legal-link {
    color: var(--text-on-dark-dim);
  }
</style>
