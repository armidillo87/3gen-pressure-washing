---
import { Image } from 'astro:assets';
import { getProjectConfig } from '@/utils/twenty';
import heroImage from '@/assets/images/hero.png';

const images = import.meta.glob<{ default: ImageMetadata }>('/src/assets/images/*.{jpeg,jpg,png,gif,webp}');

interface Props {
  heroClass: string;
  label?: string;
  h1: string;
  desc: string;
  breadcrumbs?: { label: string; href: string }[];
  bgImage?: string;
}

const { heroClass, label, h1, desc, breadcrumbs, bgImage } = Astro.props;
const siteConfig = await getProjectConfig('3gen-pressure-washing');
const { business } = siteConfig;

// Attempt to resolve the background image dynamically matching the heroClass name
const imagePath = bgImage || `/src/assets/images/${heroClass}.png`;
const resolveImage = images[imagePath] || images[imagePath.replace('.png', '.jpg')] || images[imagePath.replace('.png', '.webp')];
---

<section class={`resi-hero resi-hero--${heroClass}`}>
  {heroClass === "standard" && (
    <video autoplay loop muted playsinline class="resi-hero__bg-video" poster="https://images.pexels.com/videos/6160419/pexels-photo-6160419.jpeg?auto=compress&cs=tinysrgb&fit=crop&h=630&w=1200">
      <source src="https://videos.pexels.com/video-files/6160419/6160419-uhd_3840_2160_24fps.mp4" type="video/mp4" />
    </video>
  )}

  {heroClass !== "standard" && (
    resolveImage ? (
      <Image src={resolveImage()} alt={`${business.name} Services`} class="resi-hero__bg-img" loading="eager" fetchpriority="high" width={1920} height={1080} format="webp" />
    ) : (
      <Image src={heroImage} alt={`${business.name} Services`} class="resi-hero__bg-img" loading="eager" fetchpriority="high" width={1920} height={1080} format="webp" />
    )
  )}
  <div class="resi-hero__overlay"></div>
  
  <div class="container">
    <div class="resi-hero__content">
      {breadcrumbs && (
        <nav class="breadcrumb" aria-label="Breadcrumb">
          <a href="/">Home</a>
          {breadcrumbs.map((crumb, i) => (
            <>
              <span>&gt;</span>
              {i < breadcrumbs.length - 1
                ? <a href={crumb.href}>{crumb.label}</a>
                : <strong aria-current="page">{crumb.label}</strong>
              }
            </>
          ))}
        </nav>
      )}
      {label && <span class="resi-hero__label label">{label}</span>}
      <h1 set:html={h1} />
      <p class="resi-hero__desc">{desc}</p>
      <div class="resi-hero__ctas">
        <a href="#quote" class="btn btn--accent btn--lg">{siteConfig.cta.primary}</a>
        <a href={`tel:${business.phoneClean}`} class="btn btn--glass btn--lg">{business.phone}</a>
      </div>
    </div>
  </div>
</section>
