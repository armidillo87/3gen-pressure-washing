---
import BaseLayout from '@/layouts/BaseLayout.astro';
import Header from '@/components/Header.astro';
import Footer from '@/components/Footer.astro';
import Hero from '@/components/Hero.astro';
import QuoteForm from '@/components/QuoteForm.astro';
import SeoBlock from '@/components/SeoBlock.astro';
import TrustBar from '@/components/TrustBar.astro';
import WhyChooseUs from '@/components/WhyChooseUs.astro';
import ProcessWalkthrough from '@/components/ProcessWalkthrough.astro';

import servicesData from '@/data/services.json';
import citiesData from '@/data/cities.json';
import copyData from '@/data/copy.json';
import aboutPageData from '@/data/pages/about.json';
import { getProjectConfig, getResolvedCopy, getWebsiteCopies } from '@/utils/twenty';

export function getStaticPaths() {
  // All services in servicesData are active and ready
  return servicesData.map((service: any) => ({
    params: { service: service.slug },
    props: { service },
  }));
}

const { service } = Astro.props as { service: any };
const siteConfig = await getProjectConfig('3gen-pressure-washing');
const { business } = siteConfig;
const resolvedCopy = await getResolvedCopy(service.slug, null, service);
const serviceCopy = (copyData as any).services?.[service.slug] || null;
const serviceRadius = "Spokane & Surrounding Areas";

const websiteCopies = await getWebsiteCopies('3gen-pressure-washing');
const pageCopies = websiteCopies?.['/services/[service]'];

function compileTemplate(tmpl, s, rc) {
  if (!tmpl) return '';
  return tmpl
    .replace(/{service\.shortName}/g, s.shortName)
    .replace(/{service\.name}/g, s.name)
    .replace(/{service\.slug}/g, s.slug)
    .replace(/{resolvedCopy\.overview}/g, rc.overview)
    .replace(/{serviceCopy\?\.overview\s*\|\|\s*service\.shortDescription\s*\|\|\s*service\.description\s*\|\|\s*service\.shortDesc}/g, rc.overview);
}

const sectionHeadlineTmpl = pageCopies?.['section']?.headline || "Professional <span class='accent serif'>{service.shortName}</span>";
const sectionBodyTmpl = pageCopies?.['section']?.body || "{resolvedCopy.overview}";

const sectionHeadline = compileTemplate(sectionHeadlineTmpl, service, resolvedCopy);
const sectionBody = compileTemplate(sectionBodyTmpl, service, resolvedCopy);

const faqHeadlineTmpl = pageCopies?.['faq']?.headline || "Questions About <span class='accent serif'>{service.shortName}</span>";
const faqBodyTmpl = pageCopies?.['faq']?.body || "{item.a}";

const faqHeadline = compileTemplate(faqHeadlineTmpl, service, resolvedCopy);

const pageTitle = `${service.name} | ${business.name} | ${serviceRadius}`;
const pageDesc = `Professional ${service.shortName.toLowerCase()} in ${serviceRadius}. ${resolvedCopy.overview.substring(0, 75)}... ${business.rating}-star rated. Call ${business.phoneFormatted || business.phone}.`;

const serviceSchema = {
  "@context": "https://schema.org",
  "@type": "Service",
  "name": service.name,
  "description": resolvedCopy.overview,
  "provider": {
    "@type": "LocalBusiness",
    "name": business.name,
    "telephone": `+1${business.phoneClean}`,
    "url": business.url,
    "aggregateRating": {
      "@type": "AggregateRating",
      "ratingValue": business.rating,
      "reviewCount": business.reviewCount,
      "bestRating": "5"
    }
  },
  "areaServed": citiesData.map((c: any) => ({ "@type": "City", "name": c.name }))
};

const faqSchema = service.faq?.length ? {
  "@context": "https://schema.org",
  "@type": "FAQPage",
  "mainEntity": service.faq.map((item: any) => ({
    "@type": "Question",
    "name": item.q,
    "acceptedAnswer": { "@type": "Answer", "text": item.a }
  }))
} : null;
---

<BaseLayout title={pageTitle} description={pageDesc} schema={serviceSchema}>
  <Header slot="header" />

  <Hero
    heroClass={service.heroClass}
    label="Our Services"
    h1={`${service.name} <br><em class='serif accent'>in ${serviceRadius}.</em>`}
    desc={service.shortDescription || service.shortDesc || service.description}
    bgImage={service.primaryImage || service.image}
    breadcrumbs={[
      { label: 'Services', href: '/services/' },
      { label: service.shortName, href: `/services/${service.slug}/` }
    ]}
  />

  <TrustBar />

  {serviceCopy?.seoContent && (
    <SeoBlock content={serviceCopy.seoContent} />
  )}

  <!-- Overview -->
  {!serviceCopy?.seoContent && (
    <section class="section section--cream" style="padding: 80px 0;">
      <div class="container" style="max-width: 800px; margin: 0 auto; text-align: center;">
        <h2 style="font-family: var(--font-display); font-size: clamp(1.9rem,3.5vw,2.75rem);" set:html={sectionHeadline}></h2>
        <p style="font-size: 1.125rem; line-height: 1.9; margin-top: 1.5rem; color: var(--text-mid);" set:html={sectionBody}></p>
      </div>
    </section>
  )}

  <WhyChooseUs 
    title={`Why Choose ${siteConfig.business.shortName || siteConfig.business.name}`} 
    desc={`${siteConfig.business.name} stands behind every project. We deliver professional-grade exterior cleaning services with hot and cold temperature-controlled power washing.`} 
    reasons={aboutPageData.blocks.find((b: any) => b.type === 'WhyChooseUs')?.data.reasons || []} 
  />

  <ProcessWalkthrough 
    title={`Our ${service.shortName} Process`} 
    steps={resolvedCopy.process.map((s: any) => ({ title: s.title, description: s.desc || s.description }))}
  />

  <!-- FAQ -->
  {service.faq?.length > 0 && (
    <section class="section section--white" id="faq" style="padding: 80px 0;">
      <div class="container" style="max-width: 800px; margin: 0 auto;">
        <h2 style="text-align: center; font-family: var(--font-display); font-size: clamp(1.9rem,3.5vw,2.75rem); margin-bottom: 2rem;" set:html={faqHeadline}></h2>
        <div class="faq-list">
          {service.faq.map((item: any, i: number) => {
            const answer = faqBodyTmpl.replace(/{item\.a}/g, item.a);
            return (
              <details class="faq-item">
                <summary class="faq-item__q">{item.q}</summary>
                <p class="faq-item__a" set:html={answer}></p>
              </details>
            );
          })}
        </div>
      </div>
      {faqSchema && <script type="application/ld+json" set:html={JSON.stringify(faqSchema)} />}
    </section>
  )}

  <QuoteForm
    label={`FREE ${service.shortName.toUpperCase()} ESTIMATE`}
    h2={`Get Your Free <br><em class='serif accent'>${service.shortName} Quote.</em>`}
    formTag={`residential-${service.slug}`}
    preselectedService={service.slug}
  />

  <Footer slot="footer" />
</BaseLayout>
