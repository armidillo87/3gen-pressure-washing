---
import BaseLayout from '@/layouts/BaseLayout.astro';
import Header from '@/components/Header.astro';
import Footer from '@/components/Footer.astro';
import Hero from '@/components/Hero.astro';
import QuoteForm from '@/components/QuoteForm.astro';
import CityPills from '@/components/CityPills.astro';
import servicesData from '@/data/services.json';
import { getProjectConfig, getWebsiteCopies } from '@/utils/twenty';
import { Image } from 'astro:assets';

// Dynamically import all assets recursively
const images = import.meta.glob<{ default: ImageMetadata }>('/src/assets/images/**/*.{jpeg,jpg,png,gif}');

const siteConfig = await getProjectConfig('3gen-pressure-washing');
const { business } = siteConfig;
const activeServices = servicesData;

const websiteCopies = await getWebsiteCopies('3gen-pressure-washing');
const pageCopies = websiteCopies?.['/services'];

const heroHeadline = pageCopies?.['hero']?.headline || "What We <br><em class='serif accent'>Do.</em>";
const heroBody = pageCopies?.['hero']?.body || "Professional temperature-controlled hot and cold pressure washing, soft washing, and graffiti removal in Spokane and surrounding counties.";

const listHeadlineTemplate = pageCopies?.['services-list']?.headline || "{s.name}";
const listBodyTemplate = pageCopies?.['services-list']?.body || "{s.shortDesc}";

const areasHeadline = pageCopies?.['areas-we-serve']?.headline || "Areas We <span class='accent serif'>Serve</span>";

const schema = {
  "@context": "https://schema.org",
  "@type": "Service",
  "name": "All Services",
  "provider": {
    "@type": "LocalBusiness",
    "name": business.name,
    "telephone": `+1${business.phoneClean}`,
    "url": business.url,
    "aggregateRating": {
      "@type": "AggregateRating",
      "ratingValue": business.rating,
      "reviewCount": business.reviewCount,
      "bestRating": "5"
    }
  }
};
---

<BaseLayout title={`Our Services | ${business.name}`} schema={schema}>
  <Header slot="header" />

  <Hero
    heroClass="home"
    label="Our Services"
    h1={heroHeadline}
    desc={heroBody}
    bgImage="/src/assets/images/3gen_Equipment.webp"
    breadcrumbs={[{ label: 'Services', href: '/services/' }]}
  />

  <section class="section section--cream">
    <div class="container">
      <div class="services-grid" style="display: grid; grid-template-columns: repeat(auto-fill, minmax(320px, 1fr)); gap: 2rem;">
        {activeServices.map((s: any) => {
          const title = listHeadlineTemplate.replace(/{s\.name}/g, s.name);
          const desc = listBodyTemplate.replace(/{s\.shortDesc}/g, s.shortDescription || s.shortDesc || s.description);
          
          // Map static public path to Vite assets path dynamically
          const rawImg = s.primaryImage || s.image;
          const resolvedPath = rawImg && rawImg.startsWith('/images/services/') 
            ? rawImg.replace('/images/services/', '/src/assets/images/services/') 
            : rawImg;
          
          const imageAsset = resolvedPath ? images[resolvedPath] : null;

          return (
            <a href={`/services/${s.slug}/`} class="service-card--photo">
              {imageAsset ? (
                // @ts-ignore
                <Image src={imageAsset()} alt={s.name} class="service-card__bg" format="webp" width={480} height={360} fetchpriority="low" />
              ) : (
                <div class="service-card__bg" style="background-color: var(--charcoal); font-size: 5rem; display: flex; align-items: center; justify-content: center; color: rgba(255,255,255,0.05); font-family: var(--font-heading); font-weight: 900;">3G</div>
              )}
              <div class="service-card__photo-overlay"></div>
              <div class="service-card__photo-content">
                <h3 class="service-card__title" set:html={title}></h3>
                <p class="service-card__desc" set:html={desc}></p>
                <span class="service-card__photo-cta">Explore Service &rarr;</span>
              </div>
            </a>
          );
        })}
      </div>
    </div>
  </section>

  <section class="section section--white" style="padding: 60px 0;">
    <div class="container" style="text-align: center;">
      <h2 style="font-family: var(--font-display); margin-bottom: 1.5rem;" set:html={areasHeadline}></h2>
      <CityPills variant="light" />
    </div>
  </section>

  <QuoteForm formTag="residential-hub" />

  <Footer slot="footer" />
</BaseLayout>
