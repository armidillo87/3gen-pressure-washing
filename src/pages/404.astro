---
import BaseLayout from '@/layouts/BaseLayout.astro';
import Header from '@/components/Header.astro';
import Footer from '@/components/Footer.astro';
import siteConfig from '@/data/site-config.json';

const { business } = siteConfig;
---

<BaseLayout title={`Page Not Found | ${business.name}`} noindex>
  <Header slot="header" transparent={false} />

  <section style="min-height: 70vh; display: flex; align-items: center; justify-content: center; text-align: center; padding: 160px 20px 80px; background: var(--brand-primary-dark); color: var(--text-light);">
    <div style="max-width: 600px;">
      <div style="font-size: 4rem; color: var(--brand-secondary); margin-bottom: 2rem;">🌊</div>
      <h1 style="font-family: var(--font-display); font-size: 3rem; color: white; margin-bottom: 1rem; line-height: 1.1;">Whoops! That page got washed away.</h1>
      <p style="font-size: 1.25rem; color: var(--text-on-dark-dim); margin-bottom: 2rem; line-height: 1.6;">It looks like the link you followed was sprayed clean off the site. Don't worry, our washing crew is already on the job getting things back in order.</p>
      <a href="/" class="btn btn--accent btn--lg">Return to the Main Deck</a>
    </div>
  </section>

  <Footer slot="footer" />
</BaseLayout>
