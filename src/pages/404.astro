---
import BaseLayout from '@/layouts/BaseLayout.astro';
import Header from '@/components/Header.astro';
import Footer from '@/components/Footer.astro';
import siteConfig from '@/data/site-config.json';

const { business } = siteConfig;
---

<BaseLayout title={`Page Not Found | ${business.name}`} noindex>
  <Header slot="header" transparent={false} />

  <section style="min-height: 70vh; display: flex; align-items: center; justify-content: center; text-align: center; padding: 160px 20px 80px; background: var(--forest-deep); color: var(--text-light);">
    <div style="max-width: 600px;">
      <div style="font-size: 4rem; color: var(--gold); margin-bottom: 2rem;">⚡</div>
      <h1 style="font-family: var(--font-display); font-size: 3rem; color: var(--text-light); margin-bottom: 1rem; line-height: 1.1;">Whoops! The breaker tripped.</h1>
      <p style="font-size: 1.25rem; color: rgba(255,255,255,0.8); margin-bottom: 2rem; line-height: 1.6;">It looks like the power is out on this specific page. Don't worry, our master electricians have been dispatched and are troubleshooting the outage right now.</p>
      <a href="/" class="btn btn--gold btn--lg">Reset the Main Breaker</a>
    </div>
  </section>

  <Footer slot="footer" />
</BaseLayout>
